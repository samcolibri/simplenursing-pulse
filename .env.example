# ─── Required ─────────────────────────────────────────────────────────────────
# Apify token — scrapes TikTok, Instagram, Facebook competitor data
# Get yours at: https://console.apify.com/account/integrations
APIFY_TOKEN=

# Pinterest API v5 access token — direct token from developer portal
# Get yours at: https://developers.pinterest.com/apps/
PINTEREST_ACCESS_TOKEN=
PINTEREST_APP_ID=
PINTEREST_USERNAME=
PINTEREST_ACCOUNT_ID=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Meta Graph API — when set, fetches owned FB Page + IG Business insights
# Get yours at: https://developers.facebook.com → create Business app
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
IG_BUSINESS_ACCOUNT_ID=

# AI recommendation generation
ANTHROPIC_API_KEY=

# YouTube Data API v3 (future)
YOUTUBE_API_KEY=

# Supabase (future — for historical archive + auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
